rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if user owns the document path
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Get user's schoolId from their profile (returns null if not set)
    function getMySchoolId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId;
    }
    
    // Get user's role (returns null if not set)
    function getMyRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Check if I'm a Staff member of the school
    function amIStaff() {
      let myRole = getMyRole();
      return myRole == 'Staff';
    }
    
    // Check if I'm staff of the target user's school
    function amIStaffOfSchool(targetUserId) {
      return amIStaff() && getMySchoolId() == targetUserId;
    }
    
    // Check if I'm a student accessing my own data
    function amIStudent() {
      return getMyRole() == 'Student';
    }
    
    // Get my student docId from my profile (stored when student was created)
    function getMyStudentDocId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentDocId;
    }
    
    // Check if I'm the app developer (specific admin email)
    function amIDeveloper() {
      return request.auth.token.email == '3muhammednabeelkt@gmail.com';
    }
    
    // Check if I'm admin (Owner of a driving school)
    function amIAdmin() {
      let role = getMyRole();
      return role == 'Admin' || role == 'Owner';
    }
    
    // Check if I can access (owner, staff of the school, admin, or student accessing own data)
    function canAccess(userId) {
      return isAuth() && (isOwner(userId) || amIStaffOfSchool(userId) || amIAdmin());
    }
    
    // Check if I'm a student accessing my own student document
    function canAccessStudentData(userId, docId) {
      return isAuth() && 
             getMyRole() == 'Student' && 
             getMySchoolId() == userId &&
             getMyStudentDocId() == docId;
    }
    
    // =========================================================================
    // ADMIN ACCESS COLLECTION - For admin panel configuration
    // =========================================================================
    
    match /admin_access/{docId} {
      allow read, write: if isAuth() && amIAdmin();
    }
    
    // =========================================================================
    // ROOT USERS COLLECTION
    // =========================================================================
    
    // Root level - for listing/querying all users
    match /users {
      // Allow read for all authenticated users (needed for support chat to find admin)
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update: if isAuth() && amIAdmin();
      allow delete: if false;
    }
    
    // Individual user documents
    match /users/{userId} {
      // Allow reading: own doc, admin, Owner's staff members, students of the school
      allow read: if isAuth() && (
        isOwner(userId) || 
        amIAdmin() ||
        amIStaffOfSchool(userId) ||
        (getMyRole() == 'Student' && getMySchoolId() == userId)
      );
      allow create: if isAuth() && isOwner(userId);
      allow update: if isAuth() && (isOwner(userId) || amIAdmin());
      allow delete: if false;
      
      // ===== ACTIVE SUB COLLECTIONS =====
      
      // Students
      match /students/{docId} {
        // Allow owner/staff to read/write all students
        allow read, write: if canAccess(userId);
        // Allow students to read their own data
        allow read: if isAuth() && getMyRole() == 'Student' && getMySchoolId() == userId;
        // Allow read for verification during role selection (any authenticated user can search students in a school)
        allow read: if isAuth();
      }
      match /students/{docId}/{subcol}/{subdocId} {
        allow read, write: if canAccess(userId);
        allow read: if isAuth() && getMyRole() == 'Student' && getMySchoolId() == userId;
      }
      match /students/{docId}/{subcol}/{subdocId}/{thirdcol}/{thirddocId} {
        allow read, write: if canAccess(userId);
        allow read: if isAuth() && getMyRole() == 'Student' && getMySchoolId() == userId;
      }
      
      // License Only
      match /licenseonly/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /licenseonly/{docId}/{subcol}/{subdocId} {
        allow read, write: if canAccess(userId);
      }
      
      // Endorsement
      match /endorsement/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /endorsement/{docId}/{subcol}/{subdocId} {
        allow read, write: if canAccess(userId);
      }
      
      // Vehicle Details
      match /vehicleDetails/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /vehicleDetails/{docId}/{subcol}/{subdocId} {
        allow read, write: if canAccess(userId);
      }
      
      // DL Services
      match /dl_services/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /dl_services/{docId}/{subcol}/{subdocId} {
        allow read, write: if canAccess(userId);
      }
      
      // School Vehicles (stored under users/{userId}/school_vehicles/{docId})
      match /school_vehicles/{docId} {
        allow read, write: if canAccess(userId);
      }
      
      // Expenses
      match /expenses/{docId} {
        allow read, write: if canAccess(userId);
      }
      
      // Payments
      match /payments/{docId} {
        allow read, write: if canAccess(userId);
      }
      
      // Extra Fees
      match /extra_fees/{docId} {
        allow read, write: if canAccess(userId);
      }
      
      // Recent Activity
      match /recentActivity/{docId} {
        allow read, write: if canAccess(userId);
      }
      
      // Notifications
      match /notifications/{docId} {
        allow read, write: if canAccess(userId);
      }
      
      // Branches
      match /branches/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /branches/{docId}/{subcol}/{subdocId} {
        allow read, write: if canAccess(userId);
      }
      
      // Join Requests
      match /join_requests/{docId} {
        allow read, write: if isAuth() && (isOwner(userId) || amIAdmin());
      }
      
      // ===== DEACTIVATED SUB COLLECTIONS =====
      
      match /deactivated_students/{docId} {
        allow read, write: if canAccess(userId);
        allow read: if isAuth() && getMyRole() == 'Student' && getMySchoolId() == userId;
      }
      match /deactivated_licenseOnly/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /deactivated_endorsement/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /deactivated_vehicleDetails/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /deactivated_dl_services/{docId} {
        allow read, write: if canAccess(userId);
      }
      match /deactivated_rc_services/{docId} {
        allow read, write: if canAccess(userId);
      }
    }
    
    // =========================================================================
    // SUBSCRIPTION CODES - Admin/Owner only
    // =========================================================================
    
    match /subscription_codes/{codeId} {
      allow read, write: if isAuth() && amIAdmin();
    }
    
    // =========================================================================
    // CHAT SUPPORT - All authenticated users can participate in chats
    // =========================================================================
    
    match /chats/{chatId} {
      // Developer can read ALL chats, participants can read their chats
      allow read: if isAuth() && (
        amIDeveloper() ||
        request.auth.uid in resource.data.participants
      );
      // Allow write only for participants
      allow write: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth();
      
      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }
    
    // =========================================================================
    // USER NOTIFICATIONS - Client-side notification system
    // =========================================================================
    
    // notifications/{userId}/user_notifications/{notificationId}
    match /notifications/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      
      match /user_notifications/{notificationId} {
        allow create: if isAuth();
        allow read: if isAuth() && request.auth.uid == userId;
        allow update: if isAuth() && request.auth.uid == userId;
        allow delete: if isAuth() && request.auth.uid == userId;
      }
    }
    
    // =========================================================================
    // DEFAULT DENY
    // =========================================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
